{
  "title": "AWS Infrastructure Observability",
  "uid": "aws-infra-v1",
  "schemaVersion": 38,
  "refresh": "1m",
  "tags": [
    "aws",
    "observability",
    "cloudwatch"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "CPU Utilization",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Metrics",
          "namespace": "AWS/EC2",
          "metricName": "CPUUtilization",
          "statistic": "Average",
          "period": "60",
          "region": "us-east-1",
          "dimensions": {
            "InstanceId": "i-077303b3f359f50a5"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Memory Utilization",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Metrics",
          "namespace": "CWAgent",
          "metricName": "mem_used_percent",
          "statistic": "Average",
          "period": "60",
          "region": "us-east-1",
          "dimensions": {
            "InstanceId": "i-077303b3f359f50a5"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU Trend",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Metrics",
          "namespace": "AWS/EC2",
          "metricName": "CPUUtilization",
          "statistic": "Average",
          "period": "60",
          "region": "us-east-1",
          "dimensions": {
            "InstanceId": "i-077303b3f359f50a5"
          },
          "alias": "Avg CPU"
        },
        {
          "refId": "B",
          "queryMode": "Metrics",
          "namespace": "AWS/EC2",
          "metricName": "CPUUtilization",
          "statistic": "Maximum",
          "period": "60",
          "region": "us-east-1",
          "dimensions": {
            "InstanceId": "i-077303b3f359f50a5"
          },
          "alias": "Max CPU"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "ALB Request Count",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Metrics",
          "namespace": "AWS/ApplicationELB",
          "metricName": "RequestCount",
          "statistic": "Sum",
          "period": "60",
          "region": "us-east-1",
          "dimensions": {
            "LoadBalancer": "app/production-monitoring-alb/698c6d9914281ee1"
          },
          "alias": "Requests"
        },
        {
          "refId": "B",
          "queryMode": "Metrics",
          "namespace": "AWS/ApplicationELB",
          "metricName": "HTTPCode_Target_5XX_Count",
          "statistic": "Sum",
          "period": "60",
          "region": "us-east-1",
          "dimensions": {
            "LoadBalancer": "app/production-monitoring-alb/698c6d9914281ee1"
          },
          "alias": "5xx Errors"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "RDS Connections",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Metrics",
          "namespace": "AWS/RDS",
          "metricName": "DatabaseConnections",
          "statistic": "Average",
          "period": "60",
          "region": "us-east-1",
          "dimensions": {
            "DBInstanceIdentifier": "production-monitoring-db"
          },
          "alias": "Connections"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Server Down Status",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Metrics",
          "namespace": "AWS/EC2",
          "metricName": "StatusCheckFailed",
          "statistic": "Maximum",
          "period": "60",
          "region": "us-east-1",
          "dimensions": {
            "InstanceId": "i-077303b3f359f50a5"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "UP",
                  "color": "green"
                },
                "1": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "RDS Status",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 13
      },
      "datasource": {
        "type": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "queryMode": "Metrics",
          "namespace": "AWS/RDS",
          "metricName": "DatabaseConnections",
          "statistic": "Average",
          "period": "60",
          "region": "us-east-1",
          "dimensions": {
            "DBInstanceIdentifier": "production-monitoring-db"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "DB Connections",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    }
  ]
}